# Copy to .env.local and fill in. Never commit .env.local.
# Values come from: Supabase dashboard → Project Settings → API

# --- Public values (safe to ship in browser/extension bundles) ---
#
# These two are PUBLIC by design. The anon key is a JWT that only grants the
# "anonymous" role — security comes from Row-Level Security (RLS) on every
# table, not from hiding this key. Supabase's own docs publish anon keys in
# plaintext; the Chrome extension will ship with this same key embedded.
#
# Anyone holding this key can only do what RLS lets the anon role do. With
# our policies, that's "sign up / sign in" and nothing else until they have
# a valid session JWT for their own user.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...


# Chrome extension ID. The /extension-handoff page sends session tokens to
# this extension via chrome.runtime.sendMessage. Public — extension IDs are
# visible in the Chrome Web Store URL.
#
# Locally: set to your unpacked dev extension's ID (chrome://extensions).
# Production (Vercel): set to the published Web Store ID
# (bdphillbkbnikcjmjonkmodmlddbhegb).
NEXT_PUBLIC_EXTENSION_ID=

# --- Server-only secrets (NEVER prefix with NEXT_PUBLIC_) ---
#
# Service role key BYPASSES RLS — full god-mode on the database. Only ever
# used from server code (Next.js Route Handlers, Edge Functions, cron jobs).
# Currently used by:
#   - /api/keep-alive — counts user_keywords across all users (without the
#     service role, the cron still pings the DB but always returns count=0
#     because RLS hides every row from the anon role).
# Required for any future admin tooling that needs cross-user visibility.
#
# SUPABASE_SERVICE_ROLE_KEY=

# Gemini API key for POST /api/keywords/match — the extension's image→keywords
# matching endpoint. Get one at https://aistudio.google.com/apikey.
GEMINI_API_KEY=

# Shared secret used to authenticate the daily Vercel cron that pings
# /api/keep-alive (keeps Supabase free-tier from auto-pausing after 7 days
# of inactivity). Generate any random string and add it to BOTH:
#   - Vercel project env vars (so the cron firing sends it as a bearer)
#   - This file (so the route accepts it)
# If unset, the route accepts any caller — fine for dev, leave set in prod.
CRON_SECRET=
